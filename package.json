{
  "name": "zhizhi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:next": "next dev",
    "dev:remote": "npm run cf:preview:test:remote",
    "dev:remote:restart": "node scripts/remote-stop.mjs && npm run dev:remote",
    "dev:cf:local": "npm run cf:preview:test",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint && npm run encoding:check",
    "cf:build": "opennextjs-cloudflare build --config wrangler.toml",
    "cf:build:test": "opennextjs-cloudflare build --config wrangler.toml --env=test",
    "cf:preview": "npm run cf:build && opennextjs-cloudflare preview --config wrangler.toml",
    "cf:preview:test": "npm run cf:build:test && opennextjs-cloudflare preview --config wrangler.toml --env=test",
    "cf:preview:test:remote": "npm run cf:build:test && opennextjs-cloudflare preview --config wrangler.toml --env=test --remote",
    "cf:deploy": "opennextjs-cloudflare deploy --config wrangler.toml",
    "cf:deploy:test": "opennextjs-cloudflare deploy --config wrangler.toml --env=test",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply zhizhi --local --config wrangler.toml",
    "db:migrate:test:local": "wrangler d1 migrations apply zhizhi-test --local --env test --config wrangler.toml",
    "db:migrate:test": "wrangler d1 migrations apply zhizhi-test --remote --env test --config wrangler.toml",
    "db:studio": "drizzle-kit studio",
    "admin:create:local": "node scripts/create-admin.mjs --local",
    "admin:create:remote": "node scripts/create-admin.mjs --remote --config wrangler.toml",
    "admin:create:test:local": "node scripts/create-admin.mjs --local --db zhizhi-test --env test --config wrangler.toml",
    "admin:create:test": "node scripts/create-admin.mjs --remote --db zhizhi-test --env test --config wrangler.toml",
    "admin:promote:local": "node scripts/promote-admin.mjs --local",
    "admin:promote:remote": "node scripts/promote-admin.mjs --remote --config wrangler.toml",
    "admin:promote:test:local": "node scripts/promote-admin.mjs --local --db zhizhi-test --env test --config wrangler.toml",
    "admin:promote:test": "node scripts/promote-admin.mjs --remote --db zhizhi-test --env test --config wrangler.toml",
    "ai-term:validate": "node scripts/ai-term-validate-pro.mjs",
    "ai-term:import:dry-run": "node scripts/ai-term-import-dry-run.mjs",
    "ai-term:diagram:check": "node scripts/ai-term-diagram-check.mjs",
    "ai-term:diagram:compress:dry-run": "node scripts/ai-term-diagram-compress-dry-run.mjs",
    "ai-term:sources:match": "node scripts/ai-term-sources-match.mjs",
    "ai-term:check": "node scripts/ai-term-check.mjs",
    "ai-term:sources:index": "node scripts/ai-term-sources-index.mjs",
    "ai-term:push:prod": "node scripts/ai-term-push-prod.mjs",
    "remote:stop": "node scripts/remote-stop.mjs",
    "test:public-api": "node scripts/test-public-api.mjs",
    "test:admin-regression": "node scripts/test-admin-regression.mjs",
    "test:tools": "node --experimental-strip-types --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/test-tools.mjs",
    "encoding:check": "node scripts/check-encoding.mjs",
    "encoding:fix": "node scripts/fix-encoding.mjs",
    "cf:preview:only": "opennextjs-cloudflare preview --config wrangler.toml"
  },
  "dependencies": {
    "@jsquash/avif": "^2.1.1",
    "@jsquash/jpeg": "^1.6.0",
    "@jsquash/oxipng": "^2.3.0",
    "@jsquash/png": "^3.1.1",
    "@jsquash/webp": "^1.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "tailwind-merge": "^3.5.0",
    "unified": "^11.0.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260422.1",
    "@opennextjs/cloudflare": "^1.19.3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.90.0"
  }
}
